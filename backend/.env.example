# ------------ General ------------
NODE_ENV=development
PORT=5001

# ------------ Database ------------
MONGO_URI=mongodb://127.0.0.1:27017/artcollab

# ------------ Auth / Security ------------
# Use a long random string in your real .env
JWT_SECRET=change-me-super-secret
JWT_EXPIRE=7d

# Bcrypt cost factor (12 is OK for dev)
BCRYPT_ROUNDS=12

# ------------ CORS / Frontend URL ------------
# URL of the frontend dev server
FRONTEND_URL=http://localhost:5173

# ------------ Rate Limiting ------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ------------ Mailtrap (Password Reset) ------------
# Get these from https://mailtrap.io > Email Testing > SMTP Settings
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_username
MAIL_PASS=your_mailtrap_password

# Sender that will appear in the password reset email
MAIL_FROM="ArtCollab <no-reply@artcollab.test>"
